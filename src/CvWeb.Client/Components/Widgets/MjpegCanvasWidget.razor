@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMockStreamService MockStreams

<canvas id="@CanvasId" class="decoder-canvas" width="520" height="280" aria-label="MJPEG decoding canvas"></canvas>

<div class="metric-chip-row">
    <span class="metric-chip">Boundaries: @BoundaryCount</span>
    <span class="metric-chip">Render FPS: @RenderFps</span>
    <span class="metric-chip">Transport: multipart byte stream</span>
</div>

@code {
    private readonly string CanvasId = $"mjpeg-canvas-{Guid.NewGuid():N}";
    private readonly CancellationTokenSource _streamCts = new();

    private Task? _streamTask;

    private int BoundaryCount { get; set; }

    private int RenderFps { get; set; }

    protected override void OnInitialized()
    {
        var mjpegReader = MockStreams.SubscribeMjpeg(_streamCts.Token);
        _streamTask = ConsumeMjpegAsync(mjpegReader, _streamCts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await JS.InvokeVoidAsync("cvDashboard.startMjpegDecoder", CanvasId);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("cvDashboard.stopMjpegDecoder", CanvasId);
        }
        catch (JSException)
        {
            // Ignore teardown errors during route transitions.
        }

        _streamCts.Cancel();

        if (_streamTask is not null)
        {
            try
            {
                await _streamTask;
            }
            catch (OperationCanceledException)
            {
                // Expected during component teardown.
            }
        }

        _streamCts.Dispose();
    }

    private async Task ConsumeMjpegAsync(System.Threading.Channels.ChannelReader<MjpegStreamSample> mjpegReader, CancellationToken cancellationToken)
    {
        try
        {
            await foreach (var sample in mjpegReader.ReadAllAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    BoundaryCount = sample.BoundaryCount;
                    RenderFps = sample.RenderFps;

                    await JS.InvokeVoidAsync("cvDashboard.setMjpegBoundaryCount", CanvasId, BoundaryCount);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component teardown.
        }
    }
}
