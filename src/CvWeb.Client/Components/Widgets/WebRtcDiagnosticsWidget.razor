@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMockStreamService MockStreams

<video id="@VideoId" class="diagnostic-video" autoplay muted playsinline></video>

<div class="widget-status-row">
    <span class="status-dot @StatusClass"></span>
    <span>Peer Connection: @ConnectionState</span>
</div>

<div class="metric-chip-row">
    <span class="metric-chip">Frame Health: @FrameHealth.ToString("0.0")%</span>
    <span class="metric-chip">FPS: @FramesPerSecond.ToString("0.0")</span>
    <span class="metric-chip">Jitter: @JitterMs.ToString("0.0")ms</span>
</div>

<div class="metric-chip-row">
    <span class="metric-chip">Track Profile: @TrackProfile</span>
    <span class="metric-chip">Backend Tracks: @TrackCount</span>
</div>

@code {
    private readonly string VideoId = $"webrtc-video-{Guid.NewGuid():N}";
    private DotNetObjectReference<WebRtcDiagnosticsWidget>? _dotNetReference;

    private string ConnectionState { get; set; } = "initializing";

    private double FramesPerSecond { get; set; }

    private double JitterMs { get; set; }

    private double FrameHealth { get; set; }

    private string TrackProfile { get; set; } = "balanced";

    private int TrackCount { get; set; }

    private string StatusClass => ConnectionState switch
    {
        "connected" => "status-ok",
        "connecting" => "status-warning",
        _ => "status-critical"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await MockStreams.GetWebRtcTrackProfileAsync("balanced");
            TrackProfile = profile.Profile;
            TrackCount = profile.Tracks.Count;
        }
        catch
        {
            TrackProfile = "offline";
            TrackCount = 0;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("cvDashboard.startWebRtcDiagnostics", VideoId, _dotNetReference);
    }

    [JSInvokable]
    public Task UpdateWebRtcStats(double fps, double jitterMs, double packetLossPercent, string connectionState)
    {
        FramesPerSecond = fps;
        JitterMs = jitterMs;
        ConnectionState = connectionState;

        var fpsScore = Math.Min(100, (fps / 30d) * 100);
        var jitterPenalty = Math.Min(45, jitterMs * 1.2);
        var lossPenalty = Math.Min(35, packetLossPercent * 35);
        FrameHealth = Math.Max(0, fpsScore - jitterPenalty - lossPenalty);

        StateHasChanged();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("cvDashboard.stopWebRtcDiagnostics", VideoId);
        }
        catch (JSException)
        {
            // Ignore teardown errors during route transitions.
        }

        _dotNetReference?.Dispose();
    }
}
