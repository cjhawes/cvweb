@* FlipCard Documentation
   - Front face ingests raw multipart MJPEG byte chunks and software-decodes frame boundaries in Blazor.
   - Back face challenge/solution/stack copy remains owned by WidgetCard metadata in Dashboard.
   - This component keeps rendering in canvas and avoids native HTML5 video elements.
*@

<WidgetStatus StatusClass="@StatusClass" Label="@StatusLabel" />

<canvas id="@CanvasId"
        class="decoder-canvas"
        width="520"
        height="280"
        aria-label="Software-decoded MJPEG canvas stream"></canvas>

<MetricChipRow>
    <MetricChip Text="@($"Chunks: {ChunkCount:N0}")" />
    <MetricChip Text="@($"Boundaries: {BoundaryCount:N0}")" />
    <MetricChip Text="@($"Frame Queue: {QueuedFrames:N0}")" />
    <MetricChip Text="@($"Dropped: {DroppedFrames:N0}")" />
</MetricChipRow>

<MetricChipRow>
    <MetricChip Text="@($"Decoded: {DecodedFrames:N0}")" />
    <MetricChip Text="@($"Rendered: {RenderedFrames:N0}")" />
    <MetricChip Text="@($"Render FPS: {RenderFps:0.0}")" />
    <MetricChip Text="Transport: multipart byte stream" />
</MetricChipRow>
