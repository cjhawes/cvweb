@* FlipCard Documentation
   - Front face renders a live 1024-sensor telemetry mesh directly on HTML5 Canvas.
   - Back face documentation remains owned by the surrounding WidgetCard metadata in Dashboard.
   - This component keeps UI markup in .razor while stream/canvas orchestration lives in TelemetryGrid.razor.cs.
*@

<WidgetStatus StatusClass="@StatusClass" Label="@StatusLabel" />

<canvas id="@CanvasId"
        class="telemetry-grid-canvas decoder-canvas"
        width="960"
        height="320"
        aria-label="Synthetic telemetry grid showing 1024 IoT sensors"></canvas>

<MetricChipRow>
    <MetricChip Text="@($"Sensors: {SensorCount:N0}")" />
    <MetricChip Text="@($"Ingest: {IngestRateHz:0.0}Hz")" />
    <MetricChip Text="@($"Render: {RenderRateFps:0.0}fps")" />
    <MetricChip Text="@($"Dropped: {DroppedFrames:N0}")" />
</MetricChipRow>

<MetricChipRow>
    <MetricChip Text="@($"Alerts: {AlertSensors:N0}")" />
    <MetricChip Text="@($"CPU Mean: {CpuAveragePercent:0.0}%")" />
    <MetricChip Text="@($"Packet Loss Mean: {PacketLossAveragePercent:0.000}%")" />
    <MetricChip Text="@($"Sequence: {LastSequence:N0}")" />
</MetricChipRow>
