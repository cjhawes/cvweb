@* FlipCard Documentation
   - Front face exposes the live GPU mismatch heatmap and byte-level metrics from two static 4K references.
   - Back face copy is supplied by the surrounding WidgetCard in Dashboard to keep documentation consistent.
   - This component owns only view state and JSInterop wiring; shader execution remains in wwwroot/js/site.js.
*@
@implements IAsyncDisposable

<WidgetStatus StatusClass="@StatusClass" Label="@StatusLabel" />

<canvas id="@CanvasId"
        class="decoder-canvas"
        width="960"
        height="540"
        aria-label="GPU byte-level mismatch heatmap preview"></canvas>

<MetricChipRow>
    <MetricChip Text="@($"Backend: {BackendLabel}")" />
    <MetricChip Text="@($"Textures: {ResolutionLabel}")" />
    <MetricChip Text="@($"Compared: {ComparedBytes:N0}")" />
</MetricChipRow>

<MetricChipRow>
    <MetricChip Text="@($"Changed Bytes: {ChangedBytes:N0}")" />
    <MetricChip Text="@($"Mismatched Pixels: {MismatchedPixels:N0}")" />
    <MetricChip CssClass="@DriftClass" Text="@($"Drift: {DriftPercent:0.000}%")" />
    <MetricChip Text="@($"Pass Time: {ElapsedMilliseconds:0.00}ms")" />
</MetricChipRow>
