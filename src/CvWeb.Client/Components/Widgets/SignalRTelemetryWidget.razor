@implements IAsyncDisposable
@inject IMockStreamService MockStreams

<div class="widget-status-row">
    <span class="status-dot @ConnectionClass"></span>
    <span>@ConnectionLabel</span>
</div>

<svg class="telemetry-chart" viewBox="0 0 240 100" preserveAspectRatio="none" role="img" aria-label="Telemetry chart">
    <polyline points="@SparklinePoints" class="telemetry-line" />
</svg>

<div class="metric-chip-row">
    <span class="metric-chip">CPU: @LatestCpu.ToString("0.0")%</span>
    <span class="metric-chip">Memory: @LatestMemory.ToString("0.0")%</span>
    <span class="metric-chip">Packet Loss: @LatestPacketLoss.ToString("0.00")%</span>
</div>

@code {
    private const int MaxPoints = 40;
    private readonly List<double> _cpuPoints = new();
    private readonly CancellationTokenSource _streamCts = new();

    private Task? _streamTask;

    private double LatestCpu { get; set; }

    private double LatestMemory { get; set; }

    private double LatestPacketLoss { get; set; }

    private string ConnectionLabel { get; set; } = "Connecting to stream...";

    private string ConnectionState { get; set; } = "connecting";

    private string ConnectionClass => ConnectionState switch
    {
        "connected" => "status-ok",
        "degraded" => "status-warning",
        _ => "status-critical"
    };

    private string SparklinePoints
    {
        get
        {
            if (_cpuPoints.Count == 0)
            {
                return "0,90 240,90";
            }

            var step = _cpuPoints.Count == 1 ? 0 : 240d / (_cpuPoints.Count - 1);
            var points = _cpuPoints.Select((value, index) => $"{index * step:0.##},{100 - value:0.##}");
            return string.Join(" ", points);
        }
    }

    protected override void OnInitialized()
    {
        var telemetryReader = MockStreams.SubscribeTelemetry(_streamCts.Token);
        _streamTask = ConsumeTelemetryAsync(telemetryReader, _streamCts.Token);
    }

    public async ValueTask DisposeAsync()
    {
        _streamCts.Cancel();

        if (_streamTask is not null)
        {
            try
            {
                await _streamTask;
            }
            catch (OperationCanceledException)
            {
                // Expected during component teardown.
            }
        }

        _streamCts.Dispose();
    }

    private async Task ConsumeTelemetryAsync(System.Threading.Channels.ChannelReader<TelemetrySignal> telemetryReader, CancellationToken cancellationToken)
    {
        try
        {
            await foreach (var signal in telemetryReader.ReadAllAsync(cancellationToken))
            {
                await InvokeAsync(() =>
                {
                    LatestCpu = signal.CpuLoadPercent;
                    LatestMemory = signal.MemoryLoadPercent;
                    LatestPacketLoss = signal.PacketLossPercent;

                    _cpuPoints.Add(LatestCpu);
                    if (_cpuPoints.Count > MaxPoints)
                    {
                        _cpuPoints.RemoveAt(0);
                    }

                    ConnectionState = "connected";
                    ConnectionLabel = $"Live stream: {signal.Node} @ {signal.Timestamp:HH:mm:ss}";
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component teardown.
        }
        catch
        {
            await InvokeAsync(() =>
            {
                ConnectionState = "degraded";
                ConnectionLabel = "Telemetry stream degraded";
                StateHasChanged();
            });
        }
    }
}
