@* FlipCard Documentation
    - Front face hosts live widget output only.
    - Back face captures challenge, solution, and stack summary for quick review.
    - High-frequency diagnostics should keep stream processing outside this component and pass only presentation-ready state.
    - Keep this component presentation-only; stream and processing logic belongs in services/widgets.
*@
<article class="widget-card @FlipClass">
    <div class="widget-card-inner">
        <section class="widget-face widget-front">
            <header class="widget-header">
                <h2>@Title</h2>
                <button type="button" class="flip-toggle" title="Flip card" @onclick="ToggleFlip">[&lt;/&gt;]</button>
            </header>
            <div class="widget-content">
                @ChildContent
            </div>
        </section>

        <section class="widget-face widget-back">
            <header class="widget-header">
                <h2>@Title</h2>
                <button type="button" class="flip-toggle" title="Flip card" @onclick="ToggleFlip">[i]</button>
            </header>
            <div class="widget-back-content">
                <p><strong>Challenge:</strong> @Challenge</p>
                <p><strong>Solution:</strong> @Solution</p>
                <p><strong>Stack:</strong> @Stack</p>
                <a class="source-link" href="@SourceUrl" target="_blank" rel="noopener noreferrer">Source Code</a>
            </div>
        </section>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Challenge { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Solution { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Stack { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SourceUrl { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool IsFlipped { get; set; }

    private string FlipClass => IsFlipped ? "is-flipped" : string.Empty;

    private void ToggleFlip()
    {
        IsFlipped = !IsFlipped;
    }
}
