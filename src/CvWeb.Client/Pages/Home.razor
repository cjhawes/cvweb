@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>CV | Mission Brief</PageTitle>

<main class="cv-shell">
	<canvas id="particle-canvas" class="particle-canvas" aria-hidden="true"></canvas>
	<div class="mesh-overlay" aria-hidden="true"></div>

	<section class="hero hero-cv section" data-animate="fade-up">
		<div class="hero-main">
			<p class="kicker">Connor Hawes | Senior Software Engineer</p>
			<h1>Engineering Scalable .NET Platforms With Measurable Impact</h1>
			<p class="lede">
				Senior Software Engineer with 7+ years architecting high-performance backend systems.
				Focused on scalable microservice modernization, real-time streaming software, and resilient delivery.
			</p>
			<div class="hero-actions">
				<a class="terminal-cta terminal-cta-compact" href="mailto:cjhawes.cs@@gmail.com">
					<span class="prompt">&#64;</span>
					<span>Contact Me</span>
				</a>
				<NavLink class="terminal-cta terminal-cta-compact" href="dashboard">
					<span class="prompt">&gt;</span>
					<span>View Live Portfolio</span>
				</NavLink>
			</div>
		</div>
		<aside class="profile-panel glass-card">
			<h2>CV Snapshot</h2>
			<ul class="profile-facts">
				<li><span>Experience</span><strong>7+ years</strong></li>
				<li><span>Current Role</span><strong>Senior Software Development Engineer</strong></li>
				<li><span>Location</span><strong>Leicester, UK</strong></li>
				<li><span>Education</span><strong>BSc Computer Information Systems (1st)</strong></li>
				<li><span>Certification</span><strong>Professional Scrum Master I</strong></li>
			</ul>
		</aside>
	</section>

	<section class="info-grid section" data-animate="fade-up">
		<article class="glass-card">
			<h2>Technical Toolkit</h2>
			<ul>
				<li>.NET C#, Angular, TypeScript, SQL, Python</li>
				<li>Microservice Architecture, API Design, Scrum</li>
				<li>Azure DevOps, Git, Docker</li>
			</ul>
		</article>
		<article class="glass-card">
			<h2>Selected Outcomes</h2>
			<ul>
				<li>Led monolith-to-microservice migration that increased sensor capacity from 10,000 to 100,000</li>
				<li>Built a software-centric RTSP decoder and achieved under 150ms glass-to-glass latency</li>
				<li>Drove migration of two monolithic systems to modern .NET microservices</li>
			</ul>
		</article>
		<article class="glass-card">
			<h2>Leadership & Delivery</h2>
			<ul>
				<li>Mentored and provided technical leadership to a 13-person engineering team</li>
				<li>Established standards for code quality, testing, and system design</li>
				<li>Introduced Scrum workstreams to improve delivery predictability and velocity</li>
			</ul>
		</article>
	</section>

	<section class="timeline-section section" data-animate="fade-up">
		<h2 class="section-title">Career Snapshot</h2>
		<div class="career-timeline">
			<article class="timeline-item">
				<p class="timeline-meta">Telent | June 2023 - Present</p>
				<h3>Senior Software Development Engineer</h3>
				<p>Led platform modernization from monolith to distributed services and scaled system sensor capability tenfold.</p>
			</article>
			<article class="timeline-item">
				<p class="timeline-meta">Telent | Sep 2020 - June 2023</p>
				<h3>Software Development Engineer</h3>
				<p>Designed real-time RTSP decoding software and drove strategic product upgrades across legacy .NET and Angular estates.</p>
			</article>
			<article class="timeline-item">
				<p class="timeline-meta">Telent | Sep 2018 - Sep 2020</p>
				<h3>Graduate Software Development Engineer</h3>
				<p>Delivered product stability improvements, resolved complex support issues, and earned a Gold STEM contribution award.</p>
			</article>
		</div>
	</section>

	<section class="portfolio-preview section" data-animate="fade-up">
		<h2 class="section-title">Portfolio Preview</h2>
		<div class="portfolio-grid">
			<article class="portfolio-card">
				<h3>Real-Time Telemetry</h3>
				<p>SignalR streaming, live charting, and alert triage to demonstrate operational observability under load.</p>
			</article>
			<article class="portfolio-card">
				<h3>Video & Diagnostics</h3>
				<p>MJPEG byte-boundary decoding and WebRTC health scoring to expose stream behavior beyond standard video controls.</p>
			</article>
			<article class="portfolio-card">
				<h3>WASM Processing</h3>
				<p>Client-side image diff analysis in Blazor WebAssembly for fast camera drift detection and browser-local logic.</p>
			</article>
		</div>
	</section>

	<section class="cta-section section" data-animate="fade-up">
		<p class="cta-caption">Explore the full interactive project showcase and live engineering signals.</p>
		<NavLink class="terminal-cta" href="dashboard">
			<span class="prompt">&gt;</span>
			<span>Open Portfolio Dashboard.</span>
		</NavLink>
	</section>
</main>

@code {
	private readonly string _landingOwnerToken = $"home-{Guid.NewGuid():N}";

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await JS.InvokeVoidAsync("cvLanding.init", _landingOwnerToken);
		}
	}

	public async ValueTask DisposeAsync()
	{
		try
		{
			await JS.InvokeVoidAsync("cvLanding.dispose", _landingOwnerToken);
		}
		catch (JSException)
		{
			// Ignore teardown errors during route transitions.
		}
		catch (InvalidOperationException)
		{
			// Ignore disposal calls when JS runtime is unavailable.
		}
	}
}
