@page "/dashboard"
@page "/control-room"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMockStreamService MockStreams

<PageTitle>Portfolio Dashboard</PageTitle>

<main class="dashboard-shell cv-shell">
    <canvas id="particle-canvas" class="particle-canvas" aria-hidden="true"></canvas>
    <div class="mesh-overlay" aria-hidden="true"></div>

    <header class="dashboard-header section" data-animate="fade-up">
        <p class="kicker">Portfolio Evidence | Live Technical Sandbox</p>
        <h1>Interactive Engineering Portfolio</h1>
        <p class="lede">
            Each project below showcases a specific engineering capability with live behavior, measurable outputs,
            and concise architecture rationale via card flip.
        </p>
        <NavLink class="terminal-cta terminal-cta-compact" href="">
            <span class="prompt">&lt;</span>
            <span>Back to CV Overview</span>
        </NavLink>
    </header>

    <section class="widget-grid section">
        <WidgetCard Title="Project 01 | GPGPU Alignment Checker"
                Challenge="Physical camera drift can be invisible to the human eye but still degrade downstream analytics."
                Solution="A fragment shader compares two static 4K reference textures channel-by-channel and returns byte-level drift metrics in milliseconds."
                Stack="C#, Blazor WASM, JS Interop, WebGL2"
                SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/GpuAlignmentChecker.razor">
            <GpuAlignmentChecker />
        </WidgetCard>

        <WidgetCard Title="Project 02 | SignalR IoT Telemetry"
                    Challenge="Polling introduces latency and misses micro-spikes during operational incidents."
                    Solution="A SignalR stream pushes aggressive telemetry updates into a live sparkline and metric panel."
                    Stack="C#, Blazor WASM, SignalR"
                    SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/SignalRTelemetryWidget.razor">
            <SignalRTelemetryWidget />
        </WidgetCard>

        <WidgetCard Title="Project 03 | MJPEG Canvas Decoder"
                    Challenge="Standard video elements hide frame-boundary behavior and payload rhythm under network load."
                    Solution="A raw multipart byte stream is read directly and decoded into frame boundaries rendered at 30fps on canvas."
                    Stack="C#, Blazor WASM, JS Interop, Canvas"
                    SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/MjpegDecoder.razor">
            <MjpegDecoder />
        </WidgetCard>

        <WidgetCard Title="Project 04 | AI Alarm Triage"
                    Challenge="Noisy telemetry floods operators with low-value alerts and slows response time."
                    Solution="A browser-local scoring model classifies incoming telemetry into priority alerts and surfaces only what matters."
                    Stack="C#, Blazor WASM"
                    SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/AiAlarmTriageWidget.razor">
            <AiAlarmTriageWidget />
        </WidgetCard>

        <WidgetCard Title="Project 05 | WebRTC Diagnostics"
                    Challenge="Connection quality changes faster than static health checks can capture."
                    Solution="A peer connection loop runs continuous diagnostics and calculates live frame health from RTC stats."
                    Stack="C#, Blazor WASM, JS Interop, WebRTC"
                    SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/WebRtcDiagnosticsWidget.razor">
            <WebRtcDiagnosticsWidget />
        </WidgetCard>

        <WidgetCard Title="Project 06 | Synthetic Telemetry Grid"
                    Challenge="Operators need to observe high-density sensor fields at 60Hz without overwhelming the UI thread."
                    Solution="A worker simulates 1,024 IoT sensors and streams frames into a Canvas renderer backed by a circular frame buffer."
                    Stack="C#, Blazor WASM, JS Interop, Web Worker, Canvas"
                    SourceUrl="https://github.com/cjhawes/cvweb/blob/main/src/CvWeb.Client/Components/Widgets/TelemetryGrid.razor">
            <TelemetryGrid />
        </WidgetCard>
    </section>
</main>

@code {
    private readonly string _landingOwnerToken = $"dashboard-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await MockStreams.StartAsync();
            await JS.InvokeVoidAsync("cvLanding.init", _landingOwnerToken);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await MockStreams.StopAsync();
            await JS.InvokeVoidAsync("cvDashboard.disposeAll");
            await JS.InvokeVoidAsync("cvLanding.dispose", _landingOwnerToken);
        }
        catch (JSException)
        {
            // Ignore teardown errors during route transitions.
        }
        catch (InvalidOperationException)
        {
            // Ignore disposal calls when JS runtime is unavailable.
        }
    }
}
